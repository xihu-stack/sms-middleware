# 短信中间件配置示例
# 用法（PowerShell）：
#   Get-Content config.example.env | ForEach-Object { ... }
# 或简单方式：复制本文件，按需修改后用以下命令加载再运行：
#   cmd /c "for /f \"eol=# tokens=*\" %a in (config.local.env) do set %a" & sms-middleware.exe
# 推荐直接在系统环境变量或启动脚本里设置这些变量。

# HTTP 监听地址（内网）
LISTEN=:8080

# 来源 IP 白名单（逗号分隔，支持单 IP 和 CIDR）。空 = 全部拒绝（失败关闭）
# 填你的监控系统所在服务器 IP / 网段
IP_ALLOWLIST=10.0.0.0/8,192.168.0.0/16

# 阿里云短信配置
ALIYUN_REGION=cn-hangzhou
ALIYUN_ACCESS_KEY_ID=你的AccessKeyId
ALIYUN_ACCESS_KEY_SECRET=你的AccessKeySecret
ALIYUN_SIGN_NAME=监控告警
ALIYUN_TEMPLATE_CODE=SMS_xxxxxxxxx
# 模板里的变量名（模板内容形如 ${content}），默认 content
ALIYUN_TEMPLATE_PARAM_KEY=content
# 调阿里云超时
ALIYUN_TIMEOUT=5s
# 阿里云 SMS 服务端点（一般无需改）
ALIYUN_ENDPOINT=https://dysmsapi.aliyuncs.com
